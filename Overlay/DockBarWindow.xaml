<Window x:Class="QuickPanel.Overlay.DockBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickPanel Dock"
        Width="220" Height="600"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}"
        ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize">

    <!-- El contenido se traslada en X para deslizar dentro/fuera de pantalla.
         La ventana es más ancha que la barra para alojar la pestaña "<" y la
         cápsula de carpeta que sobresale a la izquierda. -->
    <Grid x:Name="RootGrid">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" X="0" Y="0"/>
        </Grid.RenderTransform>

        <!-- Pestaña colapsada "<" (anclada a la derecha, centrada vertical) -->
        <Border x:Name="Tab"
                Width="18" Height="64"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                CornerRadius="8,0,0,8"
                Background="{DynamicResource Md3PrimaryContainer}"
                Cursor="Hand"
                MouseEnter="Tab_MouseEnter"
                MouseLeftButtonUp="Tab_Click">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="-2" Opacity="0.35" Color="#000000"/>
            </Border.Effect>
            <TextBlock Text="‹" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource Md3OnPrimaryContainer}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Barra desplegada -->
        <Border x:Name="Bar"
                Width="64"
                HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Margin="0,16,8,16"
                CornerRadius="32"
                Background="{DynamicResource Md3SurfaceContainer}"
                Visibility="Collapsed"
                MouseLeave="Bar_MouseLeave">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
            </Border.Effect>

            <DockPanel LastChildFill="True" Margin="0,12,0,12">
                <!-- Logo (fijo, arriba) -->
                <Border DockPanel.Dock="Top"
                        Width="44" Height="44" Margin="0,0,0,8"
                        CornerRadius="22"
                        Background="{DynamicResource Md3Primary}"
                        HorizontalAlignment="Center">
                    <Canvas Width="22" Height="22">
                        <Rectangle Canvas.Left="1" Canvas.Top="3" Width="4.5" Height="16" RadiusX="1.5" RadiusY="1.5"
                                   Fill="{DynamicResource Md3OnPrimary}"/>
                        <Rectangle Canvas.Left="8.5" Canvas.Top="3" Width="12.5" Height="3" RadiusX="1.5" RadiusY="1.5"
                                   Fill="{DynamicResource Md3OnPrimary}"/>
                        <Rectangle Canvas.Left="8.5" Canvas.Top="9.5" Width="12.5" Height="3" RadiusX="1.5" RadiusY="1.5"
                                   Fill="{DynamicResource Md3OnPrimary}"/>
                        <Rectangle Canvas.Left="8.5" Canvas.Top="16" Width="9" Height="3" RadiusX="1.5" RadiusY="1.5"
                                   Fill="{DynamicResource Md3OnPrimary}"/>
                    </Canvas>
                </Border>

                <!-- "+" Agregar app (fijo, marca el inicio de la lista) -->
                <Border DockPanel.Dock="Top"
                        x:Name="AddBtn"
                        Width="44" Height="44" Margin="0,0,0,6"
                        CornerRadius="22"
                        Background="{DynamicResource Md3PrimaryContainer}"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        MouseLeftButtonUp="Add_Click">
                    <TextBlock Text="＋" FontSize="20"
                               Foreground="{DynamicResource Md3OnPrimaryContainer}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- ⚙ Configuración (fijo, abajo de todo) -->
                <Border DockPanel.Dock="Bottom"
                        Width="44" Height="44" Margin="0,6,0,0"
                        CornerRadius="22"
                        Background="{DynamicResource Md3SurfaceContainerHigh}"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        MouseLeftButtonUp="Gear_Click">
                    <TextBlock Text="⚙" FontSize="18"
                               Foreground="{DynamicResource Md3OnSurface}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Separador visible "_" entre apps y configuración (fijo) -->
                <Border DockPanel.Dock="Bottom"
                        Width="28" Height="2" Margin="0,6,0,2"
                        CornerRadius="1"
                        Background="{DynamicResource Md3OnSurfaceVariant}"
                        Opacity="0.4"
                        HorizontalAlignment="Center"/>

                <!-- Zona scrolleable de apps + carpetas (orden invertido vs Material) -->
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="AppsList" HorizontalAlignment="Center"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
