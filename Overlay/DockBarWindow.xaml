<Window x:Class="QuickPanel.Overlay.DockBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickPanel Dock"
        Width="220"
        Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">

    <!-- El contenido se traslada en X para deslizar dentro/fuera de pantalla.
         La ventana es más ancha que la barra para alojar la pestaña "<" y la
         cápsula de carpeta que sobresale a la izquierda. -->
    <Grid x:Name="RootGrid">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform"
                    X="0"
                    Y="0"/>
        </Grid.RenderTransform>

        <!-- Pestaña colapsada "<" (anclada a la derecha, centrada vertical).
             Margin derecho: Windows reserva ~7-8px invisibles alrededor de la ventana
             para la sombra/efectos de DWM, que SÍ cuentan en GetWindowRect pero NO se ven.
             Sin este margen, el borde derecho de la pestaña (que se calcula pegado a ese
             borde "lógico") queda mitad dentro / mitad en esa franja invisible, y se ve
             como si sobresaliera de la ventana del navegador. Esto es puramente visual:
             no mueve Left/Width de la ventana, así que la zona de hover y el anclaje de
             paneles (BarRect) quedan exactamente igual que antes. -->
        <Border x:Name="Tab"
                Width="18"
                Height="64"
                Margin="0,0,7,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                CornerRadius="8,0,0,8"
                Background="{DynamicResource Md3PrimaryContainer}"
                Cursor="Hand"
                MouseLeftButtonUp="Tab_Click">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                        ShadowDepth="-2"
                        Opacity="0.35"
                        Color="#000000"/>
            </Border.Effect>
            <TextBlock Text="‹"
                    FontSize="20"
                    FontWeight="Bold"
                       Foreground="{DynamicResource Md3OnPrimaryContainer}"
                       HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
        </Border>

        <!-- Barra desplegada -->
        <Border x:Name="Bar"
                Width="64"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Margin="0,16,14,16"
                CornerRadius="32"
                Background="{DynamicResource Md3SurfaceContainer}"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                        ShadowDepth="0"
                        Opacity="0.45"
                        Color="#000000"/>
            </Border.Effect>

            <DockPanel LastChildFill="True"
                    Margin="0,12,0,12">
                <!-- Logo (fijo, arriba) — mismo icono que el Store/favicon:
                     marco redondeado con la píldora del panel lateral a la derecha.
                     Se dibuja con Md3OnPrimary, así sigue cambiando de color con el
                     tema exactamente igual que el logo anterior. -->
                <Border DockPanel.Dock="Top"
                        Width="44"
                        Height="44"
                        Margin="0,0,0,8"
                        CornerRadius="22"
                        Background="{DynamicResource Md3Primary}"
                        HorizontalAlignment="Center">
                    <Viewbox Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Canvas Width="148"
                                Height="136">
                            <!-- Marco exterior (trazo) -->
                            <Rectangle Canvas.Left="6.5"
                                    Canvas.Top="6.5"
                                    Width="135"
                                    Height="123"
                                    RadiusX="12.5"
                                    RadiusY="12.5"
                                    Stroke="{DynamicResource Md3OnPrimary}"
                                    StrokeThickness="13"/>
                            <!-- Píldora del panel lateral -->
                            <Rectangle Canvas.Left="103"
                                    Canvas.Top="24"
                                    Width="26"
                                    Height="88"
                                    RadiusX="13"
                                    RadiusY="13"
                                    Fill="{DynamicResource Md3OnPrimary}"/>
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- "+" Agregar app (fijo, marca el inicio de la lista) -->
                <Border DockPanel.Dock="Top"
                        x:Name="AddBtn"
                        Width="44"
                        Height="44"
                        Margin="0,0,0,6"
                        CornerRadius="22"
                        Background="{DynamicResource Md3PrimaryContainer}"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        MouseLeftButtonUp="Add_Click">
                    <TextBlock Text="＋"
                            FontSize="20"
                               Foreground="{DynamicResource Md3OnPrimaryContainer}"
                               HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                </Border>

                <!-- ⚙ Configuración (fijo, abajo de todo) -->
                <Border DockPanel.Dock="Bottom"
                        Width="44"
                        Height="44"
                        Margin="0,6,0,0"
                        CornerRadius="22"
                        Background="{DynamicResource Md3SurfaceContainerHigh}"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        MouseLeftButtonUp="Gear_Click">
                    <TextBlock Text="⚙"
                            FontSize="18"
                               Foreground="{DynamicResource Md3OnSurface}"
                               HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                </Border>

                <!-- Separador visible "_" entre apps y configuración (fijo) -->
                <Border DockPanel.Dock="Bottom"
                        Width="28"
                        Height="2"
                        Margin="0,6,0,2"
                        CornerRadius="1"
                        Background="{DynamicResource Md3OnSurfaceVariant}"
                        Opacity="0.4"
                        HorizontalAlignment="Center"/>

                <!-- Zona scrolleable de apps + carpetas (orden invertido vs Material) -->
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="AppsList"
                            HorizontalAlignment="Center"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
