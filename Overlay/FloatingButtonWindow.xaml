<Window x:Class="QuickPanel.Overlay.FloatingButtonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickPanel"
        Width="64" Height="64"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}"
        ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize">

    <Grid>
        <!-- FAB MD3: 56dp, sombra elevación 3 -->
        <Border x:Name="Fab"
                Width="56" Height="56"
                CornerRadius="28"
                Background="{DynamicResource Md3PrimaryContainer}"
                Cursor="Hand"
                MouseLeftButtonDown="Fab_MouseLeftButtonDown"
                MouseLeftButtonUp="Fab_MouseLeftButtonUp"
                MouseMove="Fab_MouseMove"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="FabScale" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.45" Color="#000000"/>
            </Border.Effect>

            <!-- Glifo del panel — mismo icono que el Store/dock/favicon: marco redondeado
                 con la píldora del panel lateral a la derecha. Ver nota de ajuste óptico
                 en DockBarWindow.xaml (mismo Canvas 148x136, mismo trazo/gap ajustados
                 para leer bien a tamaño chico). Usa Md3OnPrimaryContainer, el color que
                 ya tenía el glifo viejo, para no desentonar con el FAB. -->
            <Viewbox Width="22" Height="22">
                <Canvas Width="148" Height="136">
                    <Rectangle Canvas.Left="5.5" Canvas.Top="5.5" Width="137" Height="125"
                               RadiusX="13.5" RadiusY="13.5"
                               Stroke="{DynamicResource Md3OnPrimaryContainer}" StrokeThickness="11"/>
                    <Rectangle Canvas.Left="98" Canvas.Top="24" Width="25" Height="88"
                               RadiusX="12.5" RadiusY="12.5"
                               Fill="{DynamicResource Md3OnPrimaryContainer}"/>
                </Canvas>
            </Viewbox>
        </Border>

        <!-- Halo de modo mover -->
        <Ellipse x:Name="MoveHalo"
                 Width="64" Height="64"
                 Stroke="{DynamicResource Md3Primary}" StrokeThickness="2"
                 StrokeDashArray="3 2"
                 Visibility="Collapsed"
                 IsHitTestVisible="False"/>

        <!-- Badge de no leídos (total) -->
        <Border x:Name="Badge" Width="20" Height="20" CornerRadius="10"
                Background="#E5484D" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,4,0" Visibility="Collapsed" IsHitTestVisible="False">
            <TextBlock x:Name="BadgeText" Text="0" FontSize="11" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
