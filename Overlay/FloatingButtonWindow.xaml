<Window x:Class="QuickPanel.Overlay.FloatingButtonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickPanel"
        Width="64" Height="64"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}"
        ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize">

    <Grid>
        <!-- FAB MD3: 56dp, sombra elevación 3 -->
        <Border x:Name="Fab"
                Width="56" Height="56"
                CornerRadius="28"
                Background="{DynamicResource Md3PrimaryContainer}"
                Cursor="Hand"
                MouseLeftButtonDown="Fab_MouseLeftButtonDown"
                MouseLeftButtonUp="Fab_MouseLeftButtonUp"
                MouseMove="Fab_MouseMove"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="FabScale" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.45" Color="#000000"/>
            </Border.Effect>

            <!-- Glifo del panel -->
            <Canvas Width="22" Height="22">
                <Rectangle Canvas.Left="1" Canvas.Top="3" Width="4.5" Height="16" RadiusX="1.5" RadiusY="1.5"
                           Fill="{DynamicResource Md3OnPrimaryContainer}"/>
                <Rectangle Canvas.Left="8.5" Canvas.Top="3" Width="12.5" Height="3" RadiusX="1.5" RadiusY="1.5"
                           Fill="{DynamicResource Md3OnPrimaryContainer}"/>
                <Rectangle Canvas.Left="8.5" Canvas.Top="9.5" Width="12.5" Height="3" RadiusX="1.5" RadiusY="1.5"
                           Fill="{DynamicResource Md3OnPrimaryContainer}"/>
                <Rectangle Canvas.Left="8.5" Canvas.Top="16" Width="9" Height="3" RadiusX="1.5" RadiusY="1.5"
                           Fill="{DynamicResource Md3OnPrimaryContainer}"/>
            </Canvas>
        </Border>

        <!-- Halo de modo mover -->
        <Ellipse x:Name="MoveHalo"
                 Width="64" Height="64"
                 Stroke="{DynamicResource Md3Primary}" StrokeThickness="2"
                 StrokeDashArray="3 2"
                 Visibility="Collapsed"
                 IsHitTestVisible="False"/>
    </Grid>
</Window>
