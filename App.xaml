<Application x:Class="QuickPanel.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>

        <!-- Fallback brushes; ThemeService los reemplaza al iniciar -->
        <SolidColorBrush x:Key="Md3Primary" Color="#B7BAF7"/>
        <SolidColorBrush x:Key="Md3OnPrimary" Color="#1E1B3A"/>
        <SolidColorBrush x:Key="Md3PrimaryContainer" Color="#3D3A6B"/>
        <SolidColorBrush x:Key="Md3OnPrimaryContainer" Color="#E3E1FF"/>
        <SolidColorBrush x:Key="Md3Surface" Color="#16171D"/>
        <SolidColorBrush x:Key="Md3SurfaceContainer" Color="#1F2029"/>
        <SolidColorBrush x:Key="Md3SurfaceContainerHigh" Color="#282A35"/>
        <SolidColorBrush x:Key="Md3OnSurface" Color="#E6E6EB"/>
        <SolidColorBrush x:Key="Md3OnSurfaceVariant" Color="#A5A6B2"/>
        <SolidColorBrush x:Key="Md3Outline" Color="#43444F"/>
        <SolidColorBrush x:Key="Md3Error" Color="#F2B8B5"/>

        <FontFamily x:Key="UiFont">Segoe UI Variable, Segoe UI</FontFamily>

        <!-- Botón de barra de título -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Md3OnSurfaceVariant}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Md3SurfaceContainerHigh}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBtnClose" TargetType="Button" BasedOn="{StaticResource TitleBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle pill "Mantener activo" (modo Lite): switch + texto -->
        <Style x:Key="KeepAliveToggle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource Md3OnSurfaceVariant}"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill" Height="22" CornerRadius="11"
                                Background="{DynamicResource Md3SurfaceContainerHigh}"
                                Padding="4,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Track del switch -->
                                <Border x:Name="track" Width="24" Height="14" CornerRadius="7"
                                        Background="{DynamicResource Md3Outline}" Margin="0,0,5,0">
                                    <Ellipse x:Name="knob" Width="10" Height="10" Fill="White"
                                             HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                </Border>
                                <TextBlock x:Name="lbl" Text="Mantener activo" FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{DynamicResource Md3Primary}"/>
                                <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="knob" Property="Margin" Value="0,0,2,0"/>
                                <Setter TargetName="lbl" Property="Foreground" Value="{DynamicResource Md3Primary}"/>
                                <Setter TargetName="pill" Property="Background" Value="{DynamicResource Md3SurfaceContainerHigh}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filled button MD3 -->
        <Style x:Key="Md3FilledButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Md3Primary}"/>
            <Setter Property="Foreground" Value="{DynamicResource Md3OnPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Text button MD3 -->
        <Style x:Key="Md3TextButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Md3Primary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Md3SurfaceContainerHigh}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox MD3 con placeholder via Tag -->
        <Style x:Key="Md3TextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Md3SurfaceContainer}"/>
            <Setter Property="Foreground" Value="{DynamicResource Md3OnSurface}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Md3Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock x:Name="Placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource Md3OnSurfaceVariant}"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"/>
                                <ScrollViewer x:Name="PART_ContentHost"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource Md3OnSurfaceVariant}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Tarjeta de selección de tamaño (S/M/L): reemplaza el RadioButton nativo
             por una tarjeta con borde resaltado cuando está seleccionada. -->
        <Style x:Key="SizeCardRadio" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Width="64" Height="64" CornerRadius="14"
                                Background="{DynamicResource Md3SurfaceContainer}"
                                BorderBrush="{DynamicResource Md3Outline}" BorderThickness="1.4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Md3SurfaceContainerHigh}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Md3Primary}"/>
                                <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Md3SurfaceContainerHigh}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem MD3: filas del popup desplegable (tema oscuro/claro vía DynamicResource,
             en vez del estilo nativo de Windows que siempre abre con fondo blanco). -->
        <Style x:Key="Md3ComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="{DynamicResource Md3OnSurface}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="8"
                                Padding="{TemplateBinding Padding}" Margin="4,1">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Md3SurfaceContainerHigh}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Md3PrimaryContainer}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Md3OnPrimaryContainer}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox MD3: caja cerrada + popup desplegable, ambos con la paleta de la app. -->
        <Style x:Key="Md3ComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Md3SurfaceContainer}"/>
            <Setter Property="Foreground" Value="{DynamicResource Md3OnSurface}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource Md3ComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="Toggle"
                                          Background="Transparent" BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press" Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Border Background="{TemplateBinding Background}" CornerRadius="12"
                                    Padding="{TemplateBinding Padding}" IsHitTestVisible="False">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                       Content="{TemplateBinding SelectionBoxItem}"
                                                       ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    <TextBlock Grid.Column="1" Text="⌄" FontSize="11" Margin="8,0,2,0"
                                               Foreground="{DynamicResource Md3OnSurfaceVariant}"
                                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" PopupAnimation="Fade"
                                   MinWidth="{TemplateBinding ActualWidth}">
                                <Border Background="{DynamicResource Md3SurfaceContainerHigh}"
                                        BorderBrush="{DynamicResource Md3Outline}" BorderThickness="1"
                                        CornerRadius="12" Margin="0,4,0,0" Padding="2">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.4" Color="#000000"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
