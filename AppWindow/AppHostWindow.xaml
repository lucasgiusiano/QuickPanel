<Window x:Class="QuickPanel.AppWindow.AppHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:QuickPanel.Services"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="QuickPanel App"
        Width="440" Height="760"
        WindowStyle="None" AllowsTransparency="False" Background="{DynamicResource Md3Surface}"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Grid x:Name="RootHost" RenderTransformOrigin="1,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="HostScale" ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="GripLeftCol" Width="0"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="GripRightCol" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- Franjas de resize (6px). El Border va en Transparent (no null) porque es lo
             que mantiene el hit-test para poder arrastrar. Adentro va una barrita centrada
             que sugiere visualmente que el borde se puede deslizar. Solo se ve en el grip
             activo: el code-behind pone Opacity=1 al lado que corresponde y 0 al otro. -->
        <Thumb x:Name="GripLeft" Grid.Column="0" Width="6" Cursor="SizeWE"
               DragDelta="GripLeft_DragDelta" Opacity="0">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent">
                        <Rectangle Width="3" Height="34"
                                   RadiusX="1.5" RadiusY="1.5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Fill="{DynamicResource Md3Outline}"/>
                    </Border>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <Thumb x:Name="GripRight" Grid.Column="2" Width="6" Cursor="SizeWE"
               DragDelta="GripRight_DragDelta" Opacity="0">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent">
                        <Rectangle Width="3" Height="34"
                                   RadiusX="1.5" RadiusY="1.5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Fill="{DynamicResource Md3Outline}"/>
                    </Border>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <Border Grid.Column="1" x:Name="PanelCard"
                Background="{DynamicResource Md3Surface}"
                BorderBrush="{DynamicResource Md3Outline}" BorderThickness="0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource Md3SurfaceContainer}"
                        CornerRadius="16,16,0,0">
                    <Grid Margin="14,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0" x:Name="TitleIcon" Width="18" Height="18"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" x:Name="TitleText" Text="{loc:Loc AppHost_DefaultTitle}"
                                   VerticalAlignment="Center" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource Md3OnSurface}"
                                   TextTrimming="CharacterEllipsis"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <ToggleButton x:Name="TglKeepAlive" Style="{StaticResource KeepAliveToggle}"
                                          Visibility="Collapsed" VerticalAlignment="Center"
                                          Click="TglKeepAlive_Click"
                                          ToolTip="{loc:Loc AppHost_KeepAliveTip}"/>
                            <!-- Vínculo del tamaño de ESTE panel con el tamaño estándar de
                                 Configuración. Ventana + candado leen como una sola unidad.
                                 Candado cerrado gris = vinculado (sin acción al click).
                                 Candado abierto rojo = tamaño propio; el click lo devuelve
                                 al estándar. El code-behind alterna ambos estados. -->
                            <Button x:Name="BtnSizeLock" Click="BtnSizeLock_Click"
                                    Style="{StaticResource TitleBtn}" Width="44"
                                    ToolTip="{loc:Loc AppHost_SizeLinked}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Ventana (siempre gris: identifica de qué habla el botón) -->
                                    <Grid Width="15" Height="13" Margin="0,0,3,0">
                                        <Border BorderBrush="{DynamicResource Md3OnSurfaceVariant}"
                                                BorderThickness="1.2" CornerRadius="2.5"/>
                                        <Rectangle Height="1.2" VerticalAlignment="Top" Margin="0,3.6,0,0"
                                                   Fill="{DynamicResource Md3OnSurfaceVariant}"/>
                                    </Grid>

                                    <!-- Candado (cambia de forma y color según el estado) -->
                                    <Grid Width="13" Height="15">
                                        <Path x:Name="LockShackleClosed"
                                              Data="M3.4,7 L3.4,4.6 A3.1,3.1 0 0 1 9.6,4.6 L9.6,7"
                                              Stroke="{DynamicResource Md3OnSurfaceVariant}"
                                              StrokeThickness="1.3"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Path x:Name="LockShackleOpen" Visibility="Collapsed"
                                              Data="M3.4,7 L3.4,4.2 A3.1,3.1 0 0 1 9.3,3.1"
                                              Stroke="{DynamicResource Md3Error}"
                                              StrokeThickness="1.3"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Border x:Name="LockBody" Width="11" Height="8" CornerRadius="2"
                                                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                                BorderBrush="{DynamicResource Md3OnSurfaceVariant}"
                                                BorderThickness="1.3"/>
                                    </Grid>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnHistory" Content="🕘" Click="BtnHistory_Click"
                                    Style="{StaticResource TitleBtn}" ToolTip="{loc:Loc AppHost_History}"/>
                            <Button x:Name="BtnReload" Content="⟳" Click="BtnReload_Click"
                                    Style="{StaticResource TitleBtn}" ToolTip="{loc:Loc AppHost_Reload}"/>
                            <Button x:Name="BtnMinimize" Content="−" Click="BtnMinimize_Click"
                                    Style="{StaticResource TitleBtn}" ToolTip="{loc:Loc AppHost_Minimize}"/>
                            <Button x:Name="BtnClose" Content="✕" Click="BtnClose_Click"
                                    Style="{StaticResource TitleBtnClose}" ToolTip="{loc:Loc AppHost_Close}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" CornerRadius="0,0,16,16" ClipToBounds="True">
                    <wv2:WebView2 x:Name="Web"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
