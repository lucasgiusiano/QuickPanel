<Window x:Class="QuickPanel.Settings.HotkeyCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asignar atajo"
        Width="360" Height="200"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Border CornerRadius="20" Background="{DynamicResource Md3Surface}"
            BorderBrush="{DynamicResource Md3Outline}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <TextBlock Text="Asignar atajo" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource Md3OnSurface}" Margin="0,0,0,10"/>
                <TextBlock x:Name="Prompt" TextWrapping="Wrap" FontSize="13"
                           Foreground="{DynamicResource Md3OnSurfaceVariant}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Quitar atajo" Click="Clear_Click" Style="{StaticResource Md3TextButton}" Margin="0,0,8,0"/>
                <Button Content="Cancelar" Click="Cancel_Click" Style="{StaticResource Md3TextButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
