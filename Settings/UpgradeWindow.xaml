<Window x:Class="QuickPanel.Settings.UpgradeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickPanel — Planes"
        Width="760" Height="520"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True"
        ResizeMode="NoResize">

    <Border CornerRadius="20" Background="{DynamicResource Md3Surface}"
            BorderBrush="{DynamicResource Md3Outline}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_Drag">
                <StackPanel>
                    <TextBlock Text="Elegí tu plan" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Md3OnSurface}"/>
                    <TextBlock x:Name="SubtitleText" FontSize="12" Margin="0,2,0,0"
                               Foreground="{DynamicResource Md3OnSurfaceVariant}"/>
                </StackPanel>
                <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Style="{StaticResource TitleBtn}"/>
            </Grid>

            <!-- Tarjetas (generadas en code-behind) -->
            <UniformGrid x:Name="Cards" Grid.Row="2" Rows="1" Columns="3" Margin="0,20,0,0"/>
        </Grid>
    </Border>
</Window>
