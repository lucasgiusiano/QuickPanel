<Window x:Class="QuickPanel.Settings.ManageAppsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickPanel — Administrar apps"
        Width="460" Height="560"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True"
        ResizeMode="NoResize">

    <Border CornerRadius="20" Background="{DynamicResource Md3Surface}"
            BorderBrush="{DynamicResource Md3Outline}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16" MouseLeftButtonDown="Header_Drag">
                <TextBlock Text="Administrar apps" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource Md3OnSurface}"/>
                <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right"
                        Style="{StaticResource TitleBtn}"/>
            </Grid>

            <TextBox x:Name="SearchBox" Grid.Row="1" Style="{StaticResource Md3TextBox}"
                     Tag="Buscar app..." Margin="0,0,0,12" TextChanged="Search_Changed"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <StackPanel x:Name="Rows"/>
            </ScrollViewer>

            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Button Content="＋ Agregar app" Click="Add_Click"
                        Style="{StaticResource Md3TextButton}" HorizontalAlignment="Left"/>
                <Button Content="Listo" Click="Close_Click"
                        Style="{StaticResource Md3FilledButton}" HorizontalAlignment="Right"/>
            </Grid>
        </Grid>
    </Border>
</Window>
