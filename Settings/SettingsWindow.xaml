<Window x:Class="QuickPanel.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:QuickPanel.Services"
        Title="QuickPanel"
        Width="420" Height="560"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Scrollbar Material: riel fino, thumb redondeado, sin botones de flecha. -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0" Focusable="False"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0" Focusable="False"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="28">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" CornerRadius="4"
                                                        Margin="2,0"
                                                        Background="{DynamicResource Md3OnSurfaceVariant}"
                                                        Opacity="0.35"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20" Background="{DynamicResource Md3Surface}"
            BorderBrush="{DynamicResource Md3Outline}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20" MouseLeftButtonDown="Header_Drag">
                <TextBlock Text="{loc:Loc Settings_Title}" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource Md3OnSurface}"/>
                <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right"
                        Style="{StaticResource TitleBtn}"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>

                <!-- Mover botón -->
                <TextBlock Text="{loc:Loc Settings_ButtonPosition}" Style="{StaticResource SettingLabel}"/>
                <Button Content="{loc:Loc Settings_MoveButton}" Click="Move_Click"
                        Style="{StaticResource Md3FilledButton}" HorizontalAlignment="Left" Margin="0,0,0,20"/>

                <!-- Apps -->
                <TextBlock Text="{loc:Loc Settings_Apps}" Style="{StaticResource SettingLabel}"/>
                <Button Content="{loc:Loc Settings_ManageApps}" Click="Manage_Click"
                        Style="{StaticResource Md3FilledButton}" HorizontalAlignment="Left" Margin="0,0,0,20"/>

                <!-- Color -->
                <TextBlock Text="{loc:Loc Settings_InterfaceColor}" Style="{StaticResource SettingLabel}"/>
                <WrapPanel x:Name="Swatches" Margin="0,0,0,20"/>

                <!-- Tema -->
                <TextBlock Text="{loc:Loc Settings_Theme}" Style="{StaticResource SettingLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <RadioButton x:Name="ThemeDark" Content="{loc:Loc Theme_Dark}" GroupName="theme" Margin="0,0,12,0"
                                 Foreground="{DynamicResource Md3OnSurface}" Click="Theme_Click" Tag="Dark"/>
                    <RadioButton x:Name="ThemeLight" Content="{loc:Loc Theme_Light}" GroupName="theme" Margin="0,0,12,0"
                                 Foreground="{DynamicResource Md3OnSurface}" Click="Theme_Click" Tag="Light"/>
                    <RadioButton x:Name="ThemeSystem" Content="{loc:Loc Common_System}" GroupName="theme" Margin="0,0,12,0"
                                 Foreground="{DynamicResource Md3OnSurface}" Click="Theme_Click" Tag="System"/>
                </StackPanel>

                <!-- Tamaño panel de apps -->
                <TextBlock Text="{loc:Loc Settings_PanelSize}" Style="{StaticResource SettingLabel}"/>
                <TextBlock Text="{loc:Loc Settings_PanelSizeDesc}"
                           FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                           Foreground="{DynamicResource Md3OnSurfaceVariant}"/>
                <StackPanel x:Name="PanelSizeRow" Orientation="Horizontal" Margin="0,0,0,20"/>

                <!-- Modo de menú -->
                <TextBlock Text="{loc:Loc Settings_MenuStyle}" Style="{StaticResource SettingLabel}"/>
                <TextBlock Text="{loc:Loc Settings_MenuStyleDesc}"
                           FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                           Foreground="{DynamicResource Md3OnSurfaceVariant}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <RadioButton x:Name="ModeMaterial" Content="{loc:Loc MenuMode_Material}" GroupName="menumode" Margin="0,0,12,0"
                                 Foreground="{DynamicResource Md3OnSurface}" Click="MenuMode_Click"/>
                    <RadioButton x:Name="ModeDock" Content="{loc:Loc MenuMode_Dock}" GroupName="menumode"
                                 Foreground="{DynamicResource Md3OnSurface}" Click="MenuMode_Click"/>
                </StackPanel>

                <!-- Tamaño del menú flotante -->
                <TextBlock Text="{loc:Loc Settings_MenuSize}" Style="{StaticResource SettingLabel}"/>
                <TextBlock Text="{loc:Loc Settings_MenuSizeDesc}"
                           FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                           Foreground="{DynamicResource Md3OnSurfaceVariant}"/>
                <StackPanel x:Name="MenuSizeRow" Orientation="Horizontal" Margin="0,0,0,20"/>

                <!-- Startup -->
                <TextBlock Text="{loc:Loc Common_System}" Style="{StaticResource SettingLabel}"/>
                <CheckBox x:Name="ChkStartup" Content="{loc:Loc Settings_StartWithWindows}"
                          Foreground="{DynamicResource Md3OnSurface}" Click="Startup_Click"/>
                <CheckBox x:Name="ChkAutoHide" Content="{loc:Loc Settings_AutoHide}"
                          Foreground="{DynamicResource Md3OnSurface}" Click="AutoHide_Click" Margin="0,10,0,0"/>

                <TextBlock Text="{loc:Loc Settings_OpenAtStart}" Style="{StaticResource SettingLabel}" Margin="0,20,0,8"/>
                <ComboBox x:Name="StartAppCombo" SelectionChanged="StartApp_Changed"
                          Style="{StaticResource Md3ComboBox}"/>

                <!-- Notificaciones -->
                <TextBlock Text="{loc:Loc Settings_Notifications}" Style="{StaticResource SettingLabel}" Margin="0,20,0,8"/>
                <CheckBox x:Name="ChkBadges" Content="{loc:Loc Settings_ShowUnread}"
                          Foreground="{DynamicResource Md3OnSurface}" Click="Badges_Click"/>

                <!-- Rendimiento -->
                <TextBlock Text="{loc:Loc Settings_Performance}" Style="{StaticResource SettingLabel}" Margin="0,20,0,8"/>
                <CheckBox x:Name="ChkLite" Content="{loc:Loc Settings_LiteMode}"
                          Foreground="{DynamicResource Md3OnSurface}" Click="Lite_Click"/>
                <TextBlock Text="{loc:Loc Settings_LiteModeDesc}"
                           FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                           Foreground="{DynamicResource Md3OnSurfaceVariant}"/>

                <!-- Atajos de acciones -->
                <TextBlock Text="{loc:Loc Settings_Hotkeys}" Style="{StaticResource SettingLabel}" Margin="0,20,0,8"/>
                <TextBlock Text="{loc:Loc Settings_HotkeysDesc}"
                           FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                           Foreground="{DynamicResource Md3OnSurfaceVariant}"/>
                <StackPanel x:Name="ActionHotkeysRow"/>

                <!-- Idioma -->
                <TextBlock Text="{loc:Loc Settings_Language}" Style="{StaticResource SettingLabel}" Margin="0,20,0,8"/>
                <ComboBox x:Name="LanguageCombo" SelectionChanged="Language_Changed"
                          Style="{StaticResource Md3ComboBox}"/>

                <!-- Backup -->
                <TextBlock Text="{loc:Loc Settings_ConfigSection}" Style="{StaticResource SettingLabel}" Margin="0,20,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="{loc:Loc Common_Export}" Click="Export_Click"
                            Style="{StaticResource Md3TextButton}" Margin="0,0,8,0"/>
                    <Button Content="{loc:Loc Common_Import}" Click="Import_Click"
                            Style="{StaticResource Md3TextButton}"/>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>

            <TextBlock Grid.Row="2" x:Name="VersionText" Text="QuickPanel" FontSize="11"
                       Foreground="{DynamicResource Md3OnSurfaceVariant}" HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
