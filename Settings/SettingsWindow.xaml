<Window x:Class="QuickPanel.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickPanel — Configuración"
        Width="420" Height="560"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True"
        ResizeMode="NoResize">

    <Border CornerRadius="20" Background="{DynamicResource Md3Surface}"
            BorderBrush="{DynamicResource Md3Outline}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20" MouseLeftButtonDown="Header_Drag">
                <TextBlock Text="Configuración" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource Md3OnSurface}"/>
                <Button Content="✕" Click="Close_Click" HorizontalAlignment="Right"
                        Style="{StaticResource TitleBtn}"/>
            </Grid>

            <StackPanel Grid.Row="1">

                <!-- Mover botón -->
                <TextBlock Text="Posición del botón" Style="{StaticResource SettingLabel}"/>
                <Button Content="Mover botón (arrastralo)" Click="Move_Click"
                        Style="{StaticResource Md3FilledButton}" HorizontalAlignment="Left" Margin="0,0,0,20"/>

                <!-- Color -->
                <TextBlock Text="Color de la interfaz" Style="{StaticResource SettingLabel}"/>
                <WrapPanel x:Name="Swatches" Margin="0,0,0,20"/>

                <!-- Tamaño panel -->
                <TextBlock Text="Tamaño del panel" Style="{StaticResource SettingLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <RadioButton x:Name="SizeS" Content="S" GroupName="size" Margin="0,0,12,0"
                                 Foreground="{DynamicResource Md3OnSurface}" Click="Size_Click" Tag="360,600"/>
                    <RadioButton x:Name="SizeM" Content="M" GroupName="size" Margin="0,0,12,0"
                                 Foreground="{DynamicResource Md3OnSurface}" Click="Size_Click" Tag="440,760"/>
                    <RadioButton x:Name="SizeL" Content="L" GroupName="size" Margin="0,0,12,0"
                                 Foreground="{DynamicResource Md3OnSurface}" Click="Size_Click" Tag="520,900"/>
                </StackPanel>

                <!-- Startup -->
                <TextBlock Text="Sistema" Style="{StaticResource SettingLabel}"/>
                <CheckBox x:Name="ChkStartup" Content="Iniciar con Windows"
                          Foreground="{DynamicResource Md3OnSurface}" Click="Startup_Click"/>
            </StackPanel>

            <TextBlock Grid.Row="2" x:Name="VersionText" Text="QuickPanel" FontSize="11"
                       Foreground="{DynamicResource Md3OnSurfaceVariant}" HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
